<%- include("../layout/header", { title: "Estafeta • Dashboard" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Dashboard do Estafeta</h1>
        <p class="muted">Bem-vindo, <strong><%= user.nome %></strong>.</p>
      </div>
    </div>

    <div class="row">
      <span class="pill">Pendentes: <%= pendentes %></span>
      <span class="pill">Ativas: <%= minhasAtivas %></span>
      <span class="pill">Histórico: <%= historico %></span>
    </div>

    <hr class="divider">

    <div class="row">
      <a class="btn btn--primary" href="/estafeta/entregas">Entregas disponíveis</a>
      <a class="btn btn--ghost" href="/estafeta/minhas">Minhas entregas</a>
      <a class="btn btn--ghost" href="/estafeta/historico">Histórico</a>
    </div>
  </div>
</div>

<%- include("../layout/footer") %>
