<h2>Perfil</h2>

<p><strong>Nome:</strong> <%= user.nome %></p>
<p><strong>Username:</strong> <%= user.username %></p>
<p><strong>Email:</strong> <%= user.email %></p>
<p><strong>Morada:</strong> <%= user.morada %></p>
<p><strong>Telefone:</strong> <%= user.telefone %></p>
<p><strong>Role:</strong> <%= user.role %></p>

<% if (user.role === "cliente") { %>
  <hr>
  <h3>Histórico de Compras</h3>

  <% if (vendas.length > 0) { %>
    <% vendas.forEach(venda => { %>
      <div>
        <p><strong>Total:</strong> €<%= venda.total.toFixed(2) %></p>
        <p><strong>Data:</strong> <%= venda.createdAt ? new Date(venda.createdAt).toLocaleString() : "Sem data" %></p>
        <ul>
          <% venda.produtos.forEach(item => { %>
            <li>
              <%= item.produto ? item.produto.nome : "Produto removido" %>
              x <%= item.quantidade %>
            </li>
          <% }) %>
        </ul>
      </div>
      <hr>
    <% }) %>
  <% } else { %>
    <p>Não tens compras ainda.</p>
  <% } %>
<% } %>

<br>

<a href="/dashboard">
  <button type="button">Voltar</button>
</a>