<%- include("../layout/header", { title: "Vendas • Nova" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Nova Venda</h1>
        <p class="muted">Seleciona um cliente e adiciona produtos ao carrinho.</p>
      </div>
      <div class="page-head__actions">
        <a class="btn btn--ghost" href="/supermercado/dashboard">Voltar</a>
      </div>
    </div>
  </div>

  <div class="card">
    <form action="/vendas" method="POST" id="formVenda">
      <div class="stack">
        <div>
          <h2>Cliente</h2>
          <div class="stack">
            <div>
              <label for="cliente_nome">Nome</label>
              <input id="cliente_nome" type="text" name="cliente_nome" placeholder="Nome do cliente" required>
            </div>
            <div>
              <label for="cliente_email">Email</label>
              <input id="cliente_email" type="email" name="cliente_email" placeholder="Email do cliente" required>
            </div>
          </div>
        </div>

        <div>
          <h2>Entrega</h2>
          <div class="stack">
            <div class="row">
              <label>
                <input type="radio" name="tipoEntrega" value="loja" checked>
                Em loja
              </label>
              <label>
                <input type="radio" name="tipoEntrega" value="domicilio">
                Entrega ao domicílio
              </label>
            </div>

            <p class="muted">
              <strong>Método:</strong> <%= supermercado.metodoEntrega || "—" %>
              • <strong>Custo:</strong> €<%= Number(supermercado.custoEntrega || 0).toFixed(2) %>
            </p>
          </div>
        </div>

        <hr class="divider">

        <div>
          <h2>Adicionar Produtos</h2>
          <div class="stack">
            <div>
              <label for="pesquisa">Pesquisar</label>
              <input type="text" id="pesquisa" placeholder="Pesquisar produto...">
            </div>

            <div>
              <label for="categoria">Categoria</label>
              <select id="categoria">
                <option value="">Todas as categorias</option>
                <% categorias.forEach(categoria => { %>
                  <option value="<%= categoria._id %>"><%= categoria.nome %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </div>

        <div class="stack">
          <% produtos.forEach(produto => { %>
            <div class="produto"
              style="display:none;"
              data-id="<%= produto._id %>"
              data-nome="<%= produto.nome %>"
              data-pesquisa="<%= produto.nome.toLowerCase() %>"
              data-categoria="<%= produto.categoria ? produto.categoria._id : '' %>"
              data-preco="<%= produto.preco %>">

              <div class="stack">
                <div>
                  <strong><%= produto.nome %></strong>
                  <div class="muted">
                    Categoria: <%= produto.categoria ? produto.categoria.nome : "Sem categoria" %>
                    • Preço: €<%= produto.preco %>
                    • Stock: <%= produto.stock %>
                  </div>
                </div>

                <div class="row">
                  <div style="min-width: 160px;">
                    <label class="visually-hidden">Quantidade</label>
                    <input type="number" class="qtdProduto" min="1" max="<%= produto.stock %>" value="1">
                  </div>
                  <button type="button" class="btn btn--primary btn--sm btnAdicionar">Adicionar</button>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <hr class="divider">

        <div>
          <h2>Produtos na Venda</h2>
          <table id="tabelaVenda">
            <tr>
              <th>Produto</th>
              <th>Quantidade</th>
              <th>Preço</th>
              <th>Subtotal</th>
              <th>Ação</th>
            </tr>
          </table>
        </div>

        <div class="row row--between">
          <h3>Total: €<span id="total">0.00</span></h3>
          <button type="submit">Finalizar Venda</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const pesquisa = document.getElementById("pesquisa");
  const categoria = document.getElementById("categoria");
  const produtos = document.querySelectorAll(".produto");
  const tabelaVenda = document.getElementById("tabelaVenda");
  const totalSpan = document.getElementById("total");
  const formVenda = document.getElementById("formVenda");

  let carrinho = {};

  function filtrar() {
    const texto = pesquisa.value.toLowerCase();
    const cat = categoria.value;

    produtos.forEach(produto => {
      const nome = produto.dataset.pesquisa;
      const categoriaProduto = produto.dataset.categoria;
      const matchTexto = nome.includes(texto);
      const matchCategoria = !cat || categoriaProduto === cat;

      produto.style.display = matchTexto && matchCategoria ? "block" : "none";
    });
  }

  function atualizarTabela() {
    document.querySelectorAll(".linhaCarrinho").forEach(linha => linha.remove());

    let total = 0;

    Object.values(carrinho).forEach(item => {
      const subtotal = item.preco * item.quantidade;
      total += subtotal;

      const linha = document.createElement("tr");
      linha.className = "linhaCarrinho";

      linha.innerHTML = `
        <td>${item.nome}</td>
        <td>${item.quantidade}</td>
        <td>€${item.preco.toFixed(2)}</td>
        <td>€${subtotal.toFixed(2)}</td>
        <td><button class="btn btn--danger btn--sm" type="button" data-remover="${item.id}">Remover</button></td>
      `;

      tabelaVenda.appendChild(linha);
    });

    totalSpan.textContent = total.toFixed(2);
  }

  document.querySelectorAll(".btnAdicionar").forEach(botao => {
    botao.addEventListener("click", () => {
      const div = botao.closest(".produto");

      const id = div.dataset.id;
      const nome = div.dataset.nome;
      const preco = parseFloat(div.dataset.preco);
      const quantidade = parseInt(div.querySelector(".qtdProduto").value);

      if (!quantidade || quantidade <= 0) return;

      carrinho[id] = { id, nome, preco, quantidade };

      let input = document.getElementById("input-" + id);

      if (!input) {
        input = document.createElement("input");
        input.type = "hidden";
        input.name = `quantidades[${id}]`;
        input.id = "input-" + id;
        formVenda.appendChild(input);
      }

      input.value = quantidade;

      atualizarTabela();
    });
  });

  tabelaVenda.addEventListener("click", e => {
    if (e.target.dataset.remover) {
      const id = e.target.dataset.remover;

      delete carrinho[id];

      const input = document.getElementById("input-" + id);
      if (input) input.remove();

      atualizarTabela();
    }
  });

  pesquisa.addEventListener("input", filtrar);
  categoria.addEventListener("change", filtrar);

  filtrar();
});
</script>

<%- include("../layout/footer") %>
