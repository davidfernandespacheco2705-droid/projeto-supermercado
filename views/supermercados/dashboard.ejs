<%- include("../layout/header", { title: "Supermercado • Dashboard" }) %>

<div class="stack">
  <div class="card">
    <h1>Dashboard do Supermercado</h1>
    <p class="muted">Bem-vindo, <strong><%= user.nome %></strong></p>
    <p><strong>Supermercado:</strong> <%= supermercado.nome %></p>

    <div class="row">
      <a class="btn btn--ghost" href="/perfil">Ver Perfil</a>
      <a class="btn btn--primary" href="/produtos/novo">Novo Produto</a>
      <a class="btn btn--ghost" href="/logout">Sair</a>
    </div>
  </div>


<a href="/supermercado/produtos">
  <button type="button">Produtos</button>
</a>

<a href="/vendas/nova">
  <button type="button">Nova Venda</button>
</a>

<a href="/vendas">
  <button type="button">Vendas em caixa</button>
</a>

<a href="/supermercado/encomendas">
  <button type="button">Encomendas Online</button>
</a>

<a href="/supermercado/clientes">
  <button type="button">Clientes</button>
</a>

<a href="/logout">
  <button type="button">Logout</button>
</a>

  <div class="card">
    <h2>Os meus produtos</h2>

    <% if (produtos.length > 0) { %>
      <table>
        <tr>
          <th>Nome</th>
          <th>Categoria</th>
          <th>Preço</th>
          <th>Stock</th>
          <th>Ações</th>
        </tr>

        <% produtos.forEach(produto => { %>
          <tr>
            <td><%= produto.nome %></td>
            <td><%= produto.categoria ? produto.categoria.nome : "Sem categoria" %></td>
            <td>€<%= produto.preco %></td>
            <td><%= produto.stock %></td>
            <td>
              <a class="btn btn--ghost" href="/produtos/<%= produto._id %>/editar">Editar</a>

              <form action="/produtos/<%= produto._id %>/apagar" method="POST" style="display:inline;">
                <button type="submit">Apagar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </table>
    <% } else { %>
      <p class="muted">Ainda não existem produtos registados.</p>
    <% } %>
  </div>
</div>

<%- include("../layout/footer") %>

