<%- include("../layout/header", { title: "Market Place • Clientes" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Os Meus Clientes</h1>
        <p class="muted"><strong>Supermercado:</strong> <%= supermercado.nome %></p>
      </div>
      <div class="page-head__actions">
        <a class="btn btn--ghost" href="/supermercado/dashboard">Voltar</a>
      </div>
    </div>
  </div>

  <div class="card">
    <% if (clientes.length > 0) { %>
      <table>
        <tr>
          <th>Nome</th>
          <th>Email</th>
        </tr>

        <% clientes.forEach(cliente => { %>
          <tr>
            <td><%= cliente.nome %></td>
            <td><%= cliente.email %></td>
          </tr>
        <% }) %>
      </table>
    <% } else { %>
      <p class="muted">Ainda não existem clientes.</p>
    <% } %>
  </div>
</div>

<%- include("../layout/footer") %>
