<%- include("../layout/header", { title: "Supermercados" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Supermercados</h1>
        <p class="muted">Lista de supermercados registados.</p>
      </div>
      <div class="page-head__actions">
        <% if (session && session.role === "supermercado") { %>
          <a class="btn btn--primary" href="/supermercados/novo">Novo Supermercado</a>
        <% } %>
      </div>
    </div>
  </div>

  <div class="card">
    <table>
      <tr>
        <th>Nome</th>
        <th>Descrição</th>
        <th>Localização</th>
        <th>Horário</th>
        <th>Método Entrega</th>
        <th>Custo Entrega</th>
        <th>Aprovado</th>
      </tr>

      <% supermercados.forEach(supermercado => { %>
        <tr>
          <td><%= supermercado.nome %></td>
          <td><%= supermercado.descricao %></td>
          <td><%= supermercado.localizacao %></td>
          <td><%= supermercado.horario %></td>
          <td><%= supermercado.metodoEntrega %></td>
          <td>€<%= supermercado.custoEntrega %></td>
          <td>
            <% if (supermercado.aprovado) { %>
              <span class="pill pill--ok">Sim</span>
            <% } else { %>
              <span class="pill pill--no">Não</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </table>
  </div>
</div>

<%- include("../layout/footer") %>
