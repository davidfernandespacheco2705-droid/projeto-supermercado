<%- include("../layout/header", { title: "Supermercados • Editar" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Editar Supermercado</h1>
        <p class="muted">Atualiza os dados do supermercado.</p>
      </div>
      <div class="page-head__actions">
        <a class="btn btn--ghost" href="/supermercados">Voltar</a>
      </div>
    </div>
  </div>

  <div class="card">
    <form action="/supermercados/<%= supermercado._id %>/editar" method="POST">
      <div class="stack">
        <div>
          <label for="nome">Nome</label>
          <input id="nome" type="text" name="nome" value="<%= supermercado.nome %>" required>
        </div>

        <div>
          <label for="descricao">Descrição</label>
          <input id="descricao" type="text" name="descricao" value="<%= supermercado.descricao %>" required>
        </div>

        <div>
          <label for="localizacao">Localização</label>
          <input id="localizacao" type="text" name="localizacao" value="<%= supermercado.localizacao %>" required>
        </div>

        <div>
          <label for="horario">Horário</label>
          <input id="horario" type="text" name="horario" value="<%= supermercado.horario %>" required>
        </div>

        <div>
          <label for="metodoEntrega">Método de Entrega</label>
          <input id="metodoEntrega" type="text" name="metodoEntrega" value="<%= supermercado.metodoEntrega %>" required>
        </div>

        <div>
          <label for="custoEntrega">Custo de Entrega</label>
          <input id="custoEntrega" type="number" step="0.01" name="custoEntrega" value="<%= supermercado.custoEntrega %>" required>
        </div>

        <button type="submit">Guardar Alterações</button>
      </div>
    </form>
  </div>
</div>

<%- include("../layout/footer") %>
