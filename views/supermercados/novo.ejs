<%- include("../layout/header") %>

<h2>Novo Supermercado</h2>

<form action="/supermercados" method="POST">
  <div>
    <label>Nome</label><br>
    <input type="text" name="nome" required>
  </div>

  <br>

  <div>
    <label>Descrição</label><br>
    <input type="text" name="descricao" required>
  </div>

  <br>

  <div>
    <label>Localização</label><br>
    <input type="text" name="localizacao" required>
  </div>

  <br>

  <div>
    <label>Horário</label><br>
    <input type="text" name="horario" required>
  </div>

  <br>

  <div>
    <label>Método de Entrega</label><br>
    <input type="text" name="metodoEntrega" required>
  </div>

  <br>

  <div>
    <label>Custo de Entrega</label><br>
    <input type="number" step="0.01" name="custoEntrega" required>
  </div>

  <br>

  <button type="submit">Guardar</button>
</form>

<%- include("../layout/footer") %>