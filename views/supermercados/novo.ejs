<%- include("../layout/header", { title: "Supermercados • Novo" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Novo Supermercado</h1>
        <p class="muted">Preenche os dados do supermercado.</p>
      </div>
      <div class="page-head__actions">
        <a class="btn btn--ghost" href="/supermercados">Voltar</a>
      </div>
    </div>
  </div>

  <div class="card">
    <form action="/supermercados" method="POST">
      <div class="stack">
        <div>
          <label for="nome">Nome</label>
          <input id="nome" type="text" name="nome" required>
        </div>

        <div>
          <label for="descricao">Descrição</label>
          <input id="descricao" type="text" name="descricao" required>
        </div>

        <div>
          <label for="localizacao">Localização</label>
          <input id="localizacao" type="text" name="localizacao" required>
        </div>

        <div>
          <label for="horario">Horário</label>
          <input id="horario" type="text" name="horario" required>
        </div>

        <div>
          <label for="metodoEntrega">Método de Entrega</label>
          <input id="metodoEntrega" type="text" name="metodoEntrega" required>
        </div>

        <div>
          <label for="custoEntrega">Custo de Entrega</label>
          <input id="custoEntrega" type="number" step="0.01" name="custoEntrega" required>
        </div>

        <button type="submit">Guardar</button>
      </div>
    </form>
  </div>
</div>

<%- include("../layout/footer") %>
