<%- include("../layout/header", { title: "Admin • Produtos" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Gestão de Produtos</h1>
        <p class="muted">Visão global dos produtos registados.</p>
      </div>
      <div class="page-head__actions">
        <a class="btn btn--ghost" href="/comparar">Comparar Preços</a>
        <a class="btn btn--ghost" href="/admin/dashboard">Voltar</a>
      </div>
    </div>
  </div>

  <div class="card">
    <% if (produtos.length > 0) { %>
      <table>
        <tr>
          <th>Nome</th>
          <th>Categoria</th>
          <th>Preço</th>
          <th>Stock</th>
          <th>Supermercado</th>
        </tr>

        <% produtos.forEach(produto => { %>
          <tr>
            <td><%= produto.nome %></td>
            <td><%= produto.categoria ? produto.categoria.nome : "Sem categoria" %></td>
            <td>€<%= produto.preco %></td>
            <td><%= produto.stock %></td>
            <td><%= produto.supermercado ? produto.supermercado.nome : "Sem supermercado" %></td>
          </tr>
        <% }) %>
      </table>
    <% } else { %>
      <p class="muted">Não existem produtos registados.</p>
    <% } %>
  </div>
</div>

<%- include("../layout/footer") %>
