<%- include("../layout/header", { title: "Admin • Supermercados" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Gestão de Supermercados</h1>
        <p class="muted">Aprova, desativa e consulta detalhes.</p>
      </div>
      <div class="page-head__actions">
        <a class="btn btn--ghost" href="/admin/dashboard">Voltar</a>
      </div>
    </div>
  </div>

  <div class="card">
    <h2>Supermercados por aprovar</h2>

    <% if (supermercadosPendentes.length > 0) { %>
      <table>
        <tr>
          <th>User</th>
          <th>Ações</th>
        </tr>

        <% supermercadosPendentes.forEach(s => { %>
          <tr>
            <td><%= s.user ? s.user.username : "Sem utilizador" %></td>
            <td>
              <div class="row">
                <a class="btn btn--ghost btn--sm" href="/admin/supermercados/<%= s._id %>">Ver detalhes</a>

                <form action="/supermercados/<%= s._id %>/aprovar" method="POST" style="display:inline;">
                  <button class="btn btn--primary btn--sm" type="submit">Aprovar</button>
                </form>

                <form action="/supermercados/<%= s._id %>/rejeitar" method="POST" style="display:inline;">
                  <button class="btn btn--danger btn--sm" type="submit">Rejeitar</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </table>
    <% } else { %>
      <p class="muted">Não existem supermercados por aprovar.</p>
    <% } %>
  </div>

  <div class="card">
    <h2>Supermercados aprovados</h2>

    <% if (supermercadosAprovados.length > 0) { %>
      <table>
        <tr>
          <th>Nome</th>
          <th>Ações</th>
        </tr>

        <% supermercadosAprovados.forEach(s => { %>
          <tr>
            <td><%= s.nome %></td>
            <td>
              <div class="row">
                <a class="btn btn--ghost btn--sm" href="/admin/supermercados/<%= s._id %>">Ver detalhes</a>

                <form action="/supermercados/<%= s._id %>/rejeitar" method="POST" style="display:inline;">
                  <button class="btn btn--warning btn--sm" type="submit">Desativar</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </table>
    <% } else { %>
      <p class="muted">Não existem supermercados aprovados.</p>
    <% } %>
  </div>
</div>

<%- include("../layout/footer") %>
