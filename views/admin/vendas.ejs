<%- include("../layout/header", { title: "Admin • Vendas" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Vendas / Encomendas</h1>
        <p class="muted">Monitorização global.</p>
      </div>
      <div class="page-head__actions">
        <a class="btn btn--ghost" href="/admin/dashboard">Voltar</a>
      </div>
    </div>
  </div>

  <div class="card">
    <% if (vendas.length > 0) { %>
      <table>
        <tr>
          <th>Supermercado</th>
          <th>Cliente</th>
          <th>Total</th>
          <th>Entrega</th>
          <th>Estafeta</th>
          <th>Data</th>
        </tr>

        <% vendas.forEach(venda => { %>
          <tr>
            <td><%= venda.supermercado ? venda.supermercado.nome : "—" %></td>
            <td><%= venda.cliente ? venda.cliente.nome : "—" %></td>
            <td>€<%= venda.total.toFixed(2) %></td>
            <td>
              <% if (venda.tipoEntrega === "domicilio") { %>
                <div class="stack">
                  <span class="pill">Domicílio</span>
                  <span class="muted"><%= venda.metodoEntrega || "—" %></span>
                  <span class="pill"><%= venda.estadoEntrega || "pendente" %></span>
                </div>
              <% } else { %>
                <span class="muted">Em loja</span>
              <% } %>
            </td>
            <td><%= venda.estafeta ? venda.estafeta.nome : "—" %></td>
            <td><%= venda.createdAt ? new Date(venda.createdAt).toLocaleString() : "—" %></td>
          </tr>
        <% }) %>
      </table>
    <% } else { %>
      <p class="muted">Ainda não existem vendas/encomendas.</p>
    <% } %>
  </div>
</div>

<%- include("../layout/footer") %>
