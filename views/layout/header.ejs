<!doctype html>
<html lang="pt">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== "undefined" && title ? title : "Market Place" %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <a class="skip-link" href="#main">Saltar para o conteúdo</a>

  <header class="topbar">
    <div class="container topbar__inner">
      <a class="brand" href="<%= (session && session.id) ? '/dashboard' : '/login' %>">
        <span class="brand__mark" aria-hidden="true">MP</span>
        <span class="brand__text">Market Place</span>
      </a>

      <nav class="nav" aria-label="Navegação principal">
        <% if (session && session.id) { %>
          <% if (!(typeof minimalNav !== "undefined" && minimalNav)) { %>
            <% if (session.role === "admin") { %>
              <a class="nav__link" href="/admin/dashboard">Dashboard</a>
              <a class="nav__link" href="/admin/supermercados">Supermercados</a>
              <a class="nav__link" href="/admin/produtos">Produtos</a>
              <a class="nav__link" href="/admin/categorias">Categorias</a>
              <a class="nav__link" href="/admin/vendas">Vendas</a>
              <a class="nav__link" href="/admin/users">Utilizadores</a>
            <% } else if (session.role === "supermercado") { %>
              <a class="nav__link" href="/supermercado/dashboard">Dashboard</a>
              <a class="nav__link" href="/supermercado/produtos">Produtos</a>
              <a class="nav__link" href="/vendas">Vendas</a>
            <% } else if (session.role === "estafeta") { %>
              <a class="nav__link" href="/estafeta/dashboard">Dashboard</a>
              <a class="nav__link" href="/estafeta/entregas">Entregas</a>
            <% } else { %>
              <a class="nav__link" href="/produtos">Produtos</a>
              <a class="nav__link" href="/comparar">Comparar</a>
            <% } %>
          <% } %>

          <span class="nav__spacer" aria-hidden="true"></span>

          <a class="btn btn--ghost" href="/perfil">Perfil</a>
          <a class="btn btn--primary" href="/logout">Sair</a>
        <% } else { %>
          <!-- Sem botão "Entrar": acesso via /login -->
        <% } %>
      </nav>
    </div>
  </header>

  <main id="main" class="container page">
