<% const url = (produto && produto.imagem) ? String(produto.imagem) : ""; %>
<% const altText = (produto && produto.nome) ? String(produto.nome) : "produto"; %>
<% const isSm = (typeof size !== "undefined" && String(size) === "sm"); %>
<% const thumbClass = isSm ? "thumb thumb--sm" : "thumb"; %>
<% const placeholderClass = isSm ? "thumb thumb--sm thumb--placeholder" : "thumb thumb--placeholder"; %>

<% if (url) { %>
  <img class="<%= thumbClass %>" src="<%= url %>" alt="<%= altText %>">
<% } else { %>
  <span class="<%= placeholderClass %>" aria-label="Sem imagem" title="Sem imagem">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
      <path fill="currentColor" d="M21 19V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2ZM5 5h14v10.2l-2.6-2.6a2 2 0 0 0-2.8 0l-1.8 1.8-2.8-2.8a2 2 0 0 0-2.8 0L5 12.2V5Zm0 14v-4l3.6-3.6 2.8 2.8-3.8 3.8H5Zm14 0H9.4l5.6-5.6 4 4V19ZM8.5 9A1.5 1.5 0 1 0 8.5 6a1.5 1.5 0 0 0 0 3Z"/>
    </svg>
  </span>
<% } %>
