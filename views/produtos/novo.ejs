<%- include("../layout/header", { title: "Produtos • Novo" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Novo Produto</h1>
        <p class="muted"><strong>Supermercado:</strong> <%= supermercado.nome %></p>
      </div>
      <div class="page-head__actions">
        <a class="btn btn--ghost" href="/produtos">Voltar</a>
      </div>
    </div>
  </div>

  <div class="card">
    <form action="/produtos" method="POST" enctype="multipart/form-data">
      <div class="stack">
        <div>
          <label for="nome">Nome</label>
          <input id="nome" type="text" name="nome" placeholder="Nome do produto" required>
        </div>

        <div>
          <label for="descricao">Descrição</label>
          <input id="descricao" type="text" name="descricao" placeholder="Descrição" required>
        </div>

        <div>
          <label for="categoria">Categoria</label>
          <select id="categoria" name="categoria" required>
            <% categorias.forEach(categoria => { %>
              <option value="<%= categoria._id %>"><%= categoria.nome %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label for="preco">Preço</label>
          <input id="preco" type="number" step="0.01" name="preco" placeholder="Preço" required>
        </div>

        <div>
          <label for="imagemFile">Imagem (ficheiro)</label>
          <input id="imagemFile" type="file" name="imagemFile" accept="image/*">
          <p class="muted">Opcional. Se enviares um ficheiro, ele tem prioridade sobre o URL.</p>
        </div>

        <div>
          <label for="imagem">Imagem (URL)</label>
          <input id="imagem" type="text" name="imagem" placeholder="https://...">
        </div>

        <div>
          <label for="stock">Stock</label>
          <input id="stock" type="number" name="stock" placeholder="Stock" required>
        </div>

        <button type="submit">Guardar Produto</button>
      </div>
    </form>
  </div>
</div>

<%- include("../layout/footer") %>
