<%- include("../layout/header", { title: "Produtos • Editar" }) %>

<div class="stack">
  <div class="card card--soft">
    <div class="page-head">
      <div class="page-head__title">
        <h1>Editar Produto</h1>
        <p class="muted"><strong>Supermercado:</strong> <%= supermercado.nome %></p>
      </div>
      <div class="page-head__actions">
        <a class="btn btn--ghost" href="/produtos">Voltar</a>
      </div>
    </div>
  </div>

  <div class="card">
    <form action="/produtos/<%= produto._id %>/editar" method="POST">
      <div class="stack">
        <div>
          <label for="nome">Nome</label>
          <input id="nome" type="text" name="nome" value="<%= produto.nome %>" required>
        </div>

        <div>
          <label for="descricao">Descrição</label>
          <input id="descricao" type="text" name="descricao" value="<%= produto.descricao %>" required>
        </div>

        <div>
          <label for="categoria">Categoria</label>
          <select id="categoria" name="categoria" required>
            <% categorias.forEach(categoria => { %>
              <option value="<%= categoria._id %>" <%= produto.categoria && produto.categoria.toString() === categoria._id.toString() ? "selected" : "" %>>
                <%= categoria.nome %>
              </option>
            <% }) %>
          </select>
        </div>

        <div>
          <label for="preco">Preço</label>
          <input id="preco" type="number" step="0.01" name="preco" value="<%= produto.preco %>" required>
        </div>

        <div>
          <label for="imagem">Imagem (URL)</label>
          <input id="imagem" type="text" name="imagem" value="<%= produto.imagem %>" required>
        </div>

        <div>
          <label for="stock">Stock</label>
          <input id="stock" type="number" name="stock" value="<%= produto.stock %>" required>
        </div>

        <button type="submit">Guardar Alterações</button>
      </div>
    </form>
  </div>
</div>

<%- include("../layout/footer") %>
